# ── LLM provider ───────────────────────────────────────────
# Which chat model to use: "google" (default) or "openai".
LLM_PROVIDER=google
# Model name for the chosen provider:
#   google  -> gemini-2.0-flash   (free tier; newer flash models also work)
#   openai  -> gpt-4o-mini
LLM_MODEL=gemini-2.0-flash

# Google AI Studio key (free, no card): https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Only needed if LLM_PROVIDER=openai (also run: npm i @langchain/openai)
# OPENAI_API_KEY=your_openai_key_here

# ── Web research ───────────────────────────────────────────
# Tavily key (free tier, no card): https://app.tavily.com
TAVILY_API_KEY=your_tavily_key_here
